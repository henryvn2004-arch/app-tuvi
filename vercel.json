{
  "version": 2,
  "functions": {
    "api/lasotuvi.js": {
      "maxDuration": 60
    },
    "api/search.js": {
      "maxDuration": 30
    },
    "api/embed.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/lasotuvi",
      "dest": "/api/lasotuvi.js"
    },
    {
      "src": "/api/search",
      "dest": "/api/search.js"
    },
    {
      "src": "/api/embed",
      "dest": "/api/embed.js"
    },
    {
      "src": "/cach_cuc_all.json",
      "dest": "/public/cach_cuc_all.json"
    },
    {
      "src": "/tuvi-ansao-engine.js",
      "dest": "/public/tuvi-ansao-engine.js"
    },
    {
      "src": "/tuvi-engine.js",
      "dest": "/public/tuvi-engine.js"
    },
    {
      "src": "/api/save-laso",
      "dest": "/api/save-laso.js"
    },
    {
      "src": "/api/get-laso",
      "dest": "/api/get-laso.js"
    },
    {
      "src": "/auth-callback",
      "dest": "/public/auth-callback.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}