{
  "version": 2,
  "builds": [
    { "src": "api/lasotuvi.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/lasotuvi", "dest": "/api/lasotuvi.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/lasotuvi.py": {
      "maxDuration": 60
    }
  }
}
